# =============================================================================
# Multica Self-Hosted Deployment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# --- Ports (exposed to 127.0.0.1 only, your Caddy proxies to these) ---
SERVER_PORT=8080
WEB_PORT=3000

# --- Database ---
POSTGRES_PASSWORD=change-me-use-a-strong-password
DATABASE_URL=postgres://multica:change-me-use-a-strong-password@postgres:5432/multica?sslmode=disable

# --- Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl

# --- Email Authentication (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@example.com

# --- Frontend (use your actual domain) ---
FRONTEND_ORIGIN=https://multica.example.com
MULTICA_APP_URL=https://multica.example.com
CORS_ALLOWED_ORIGINS=https://multica.example.com
COOKIE_DOMAIN=.example.com
